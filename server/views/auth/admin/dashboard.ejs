<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>CineVillage — Dashboard</title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet"/>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --ink: #0a0a0f;
      --gold: #c9a84c;
      --gold-light: #e8c87a;
      --cream: #f5f0e8;
      --muted: #6b6b7a;
      --surface: #13131a;
      --surface2: #1c1c27;
      --border: rgba(201,168,76,0.15);
      --green: #2ecc71;
      --red: #e74c3c;
      --blue: #3498db;
      --purple: #9b59b6;
      --orange: #e67e22;
      --teal: #1abc9c;
    }

    body {
      min-height: 100vh;
      background: var(--ink);
      font-family: 'DM Sans', sans-serif;
      color: var(--cream);
      display: flex;
    }

    /* ── Sidebar ── */
    .sidebar {
      width: 240px;
      min-height: 100vh;
      background: var(--surface);
      border-right: 1px solid var(--border);
      display: flex;
      flex-direction: column;
      position: fixed;
      top: 0; left: 0; bottom: 0;
      z-index: 100;
    }
    .sidebar-brand { padding: 28px 24px 20px; border-bottom: 1px solid var(--border); }
    .brand-name { font-family: 'Playfair Display', serif; font-size: 1.3rem; font-weight: 900; color: var(--gold); }
    .brand-sub { font-size: 0.7rem; color: var(--muted); letter-spacing: 0.15em; text-transform: uppercase; margin-top: 3px; }
    .nav { flex: 1; padding: 20px 12px; }
    .nav-section { font-size: 0.65rem; font-weight: 600; color: var(--muted); letter-spacing: 0.2em; text-transform: uppercase; padding: 0 12px; margin-bottom: 8px; margin-top: 20px; }
    .nav-section:first-child { margin-top: 0; }
    .nav a { display: flex; align-items: center; gap: 10px; padding: 9px 12px; border-radius: 4px; color: var(--muted); text-decoration: none; font-size: 0.88rem; transition: all 0.15s; margin-bottom: 2px; }
    .nav a:hover { background: rgba(201,168,76,0.08); color: var(--cream); }
    .nav a.active { background: rgba(201,168,76,0.12); color: var(--gold); font-weight: 500; }
    .nav a svg { width: 16px; height: 16px; flex-shrink: 0; }
    .sidebar-footer { padding: 16px 12px; border-top: 1px solid var(--border); }
    .logout-btn { display: flex; align-items: center; gap: 10px; width: 100%; padding: 9px 12px; border-radius: 4px; background: none; border: none; color: var(--muted); font-family: 'DM Sans', sans-serif; font-size: 0.88rem; cursor: pointer; text-decoration: none; transition: all 0.15s; }
    .logout-btn:hover { background: rgba(231,76,60,0.1); color: #e74c3c; }

    /* ── Main ── */
    .main { margin-left: 240px; flex: 1; display: flex; flex-direction: column; min-height: 100vh; }
    .topbar { background: var(--surface); border-bottom: 1px solid var(--border); padding: 16px 32px; display: flex; align-items: center; justify-content: space-between; }
    .page-title { font-family: 'Playfair Display', serif; font-size: 1.4rem; font-weight: 700; color: var(--cream); }
    .topbar-right { display: flex; align-items: center; gap: 12px; font-size: 0.82rem; color: var(--muted); }
    .badge-date { background: rgba(201,168,76,0.1); border: 1px solid var(--border); color: var(--gold); padding: 4px 12px; border-radius: 20px; font-size: 0.75rem; font-weight: 500; }
    .content { padding: 32px; flex: 1; }

    /* ── Greeting Banner ── */
    .greeting-banner {
      background: linear-gradient(135deg, rgba(201,168,76,0.08) 0%, rgba(155,89,182,0.06) 100%);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 28px 32px;
      margin-bottom: 28px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      animation: fadeUp 0.4s ease both;
    }
    .greeting-text h2 {
      font-family: 'Playfair Display', serif;
      font-size: 1.5rem;
      font-weight: 700;
      color: var(--cream);
      margin-bottom: 6px;
    }
    .greeting-text p { font-size: 0.85rem; color: var(--muted); }
    .greeting-text p strong { color: var(--gold); }

    /* ── Quick Actions ── */
    .quick-actions {
      display: flex;
      gap: 10px;
      flex-shrink: 0;
    }
    .qa-btn {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 8px 16px;
      border-radius: 4px;
      font-family: 'DM Sans', sans-serif;
      font-size: 0.78rem;
      font-weight: 500;
      text-decoration: none;
      border: 1px solid var(--border);
      color: var(--muted);
      transition: all 0.2s;
      white-space: nowrap;
    }
    .qa-btn:hover { border-color: var(--gold); color: var(--gold); background: rgba(201,168,76,0.06); }
    .qa-btn svg { width: 14px; height: 14px; }

    /* ── Stat Cards ── */
    .stats-grid { display: grid; grid-template-columns: repeat(6, 1fr); gap: 14px; margin-bottom: 28px; }
    .stat-card { background: var(--surface); border: 1px solid var(--border); border-radius: 6px; padding: 20px; position: relative; overflow: hidden; animation: fadeUp 0.5s ease both; transition: transform 0.2s, border-color 0.2s; }
    .stat-card:hover { transform: translateY(-2px); border-color: rgba(201,168,76,0.3); }
    .stat-card:nth-child(2) { animation-delay: 0.05s; }
    .stat-card:nth-child(3) { animation-delay: 0.1s; }
    .stat-card:nth-child(4) { animation-delay: 0.15s; }
    .stat-card:nth-child(5) { animation-delay: 0.2s; }
    .stat-card:nth-child(6) { animation-delay: 0.25s; }
    @keyframes fadeUp { from { opacity: 0; transform: translateY(16px); } to { opacity: 1; transform: translateY(0); } }
    .stat-card::after { content: ''; position: absolute; bottom: 0; left: 0; right: 0; height: 2px; }
    .stat-card.gold::after { background: var(--gold); }
    .stat-card.green::after { background: var(--green); }
    .stat-card.blue::after { background: var(--blue); }
    .stat-card.purple::after { background: var(--purple); }
    .stat-card.orange::after { background: var(--orange); }
    .stat-card.teal::after { background: var(--teal); }
    .stat-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 12px; }
    .stat-icon { width: 34px; height: 34px; border-radius: 8px; display: flex; align-items: center; justify-content: center; }
    .stat-card.gold .stat-icon { background: rgba(201,168,76,0.12); color: var(--gold); }
    .stat-card.green .stat-icon { background: rgba(46,204,113,0.1); color: var(--green); }
    .stat-card.blue .stat-icon { background: rgba(52,152,219,0.1); color: var(--blue); }
    .stat-card.purple .stat-icon { background: rgba(155,89,182,0.1); color: var(--purple); }
    .stat-card.orange .stat-icon { background: rgba(230,126,34,0.1); color: var(--orange); }
    .stat-card.teal .stat-icon { background: rgba(26,188,156,0.1); color: var(--teal); }
    .stat-icon svg { width: 16px; height: 16px; }
    .stat-value { font-family: 'Playfair Display', serif; font-size: 2rem; font-weight: 900; line-height: 1; margin-bottom: 3px; }
    .stat-card.gold .stat-value { color: var(--gold); }
    .stat-card.green .stat-value { color: var(--green); }
    .stat-card.blue .stat-value { color: var(--blue); }
    .stat-card.purple .stat-value { color: var(--purple); }
    .stat-card.orange .stat-value { color: var(--orange); }
    .stat-card.teal .stat-value { color: var(--teal); }
    .stat-label { font-size: 0.72rem; color: var(--muted); font-weight: 400; }

    /* ── Two-column layout ── */
    .dashboard-grid { display: grid; grid-template-columns: 1.4fr 1fr; gap: 20px; margin-bottom: 24px; }

    /* ── Cards ── */
    .card { background: var(--surface); border: 1px solid var(--border); border-radius: 6px; overflow: hidden; animation: fadeUp 0.5s ease both; animation-delay: 0.15s; }
    .card-header { padding: 16px 20px; border-bottom: 1px solid var(--border); background: rgba(255,255,255,0.02); display: flex; align-items: center; justify-content: space-between; }
    .card-title { font-family: 'Playfair Display', serif; font-size: 0.95rem; font-weight: 700; color: var(--cream); display: flex; align-items: center; gap: 8px; }
    .card-title svg { width: 16px; height: 16px; color: var(--gold); }
    .card-body { padding: 16px 20px; }
    .btn-sm { padding: 5px 12px; border-radius: 3px; font-family: 'DM Sans', sans-serif; font-size: 0.7rem; font-weight: 500; text-decoration: none; letter-spacing: 0.08em; text-transform: uppercase; border: 1px solid var(--border); color: var(--muted); background: none; transition: all 0.15s; }
    .btn-sm:hover { border-color: var(--gold); color: var(--gold); }

    /* ── Table ── */
    table { width: 100%; border-collapse: collapse; }
    thead th { padding: 10px 16px; font-size: 0.66rem; font-weight: 600; color: var(--muted); letter-spacing: 0.15em; text-transform: uppercase; text-align: left; border-bottom: 1px solid var(--border); background: rgba(255,255,255,0.02); }
    tbody tr { border-bottom: 1px solid rgba(255,255,255,0.04); transition: background 0.15s; }
    tbody tr:last-child { border-bottom: none; }
    tbody tr:hover { background: rgba(201,168,76,0.04); }
    tbody td { padding: 10px 16px; font-size: 0.82rem; color: var(--cream); }
    .pill { display: inline-block; padding: 3px 10px; border-radius: 20px; font-size: 0.66rem; font-weight: 500; }
    .pill-active { background: rgba(46,204,113,0.12); color: var(--green); }
    .pill-soon { background: rgba(201,168,76,0.12); color: var(--gold); }
    .pill-live { background: rgba(231,76,60,0.12); color: var(--red); animation: pulse 2s ease infinite; }
    @keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.6; } }

    /* ── Genre Chart ── */
    .genre-row { display: flex; align-items: center; gap: 10px; margin-bottom: 10px; }
    .genre-row:last-child { margin-bottom: 0; }
    .genre-label { width: 72px; font-size: 0.76rem; color: var(--muted); text-align: right; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; flex-shrink: 0; }
    .genre-bar-wrap { flex: 1; height: 22px; background: rgba(255,255,255,0.03); border-radius: 3px; overflow: hidden; position: relative; }
    .genre-bar { height: 100%; border-radius: 3px; transition: width 0.8s ease; display: flex; align-items: center; padding-left: 8px; }
    .genre-bar span { font-size: 0.68rem; font-weight: 600; color: var(--ink); }
    .genre-colors-0 { background: var(--gold); }
    .genre-colors-1 { background: var(--green); }
    .genre-colors-2 { background: var(--blue); }
    .genre-colors-3 { background: var(--purple); }
    .genre-colors-4 { background: var(--orange); }
    .genre-colors-5 { background: var(--teal); }

    /* ── Chain Breakdown ── */
    .chain-item { display: flex; align-items: center; justify-content: space-between; padding: 10px 0; border-bottom: 1px solid rgba(255,255,255,0.04); }
    .chain-item:last-child { border-bottom: none; }
    .chain-name { font-size: 0.82rem; color: var(--cream); font-weight: 500; }
    .chain-count { font-size: 0.78rem; color: var(--gold); font-weight: 600; background: rgba(201,168,76,0.1); padding: 2px 10px; border-radius: 12px; }

    /* ── Today Timeline ── */
    .timeline { position: relative; padding-left: 24px; }
    .timeline::before { content: ''; position: absolute; left: 7px; top: 4px; bottom: 4px; width: 2px; background: var(--border); border-radius: 1px; }
    .tl-item { position: relative; padding: 8px 0 16px; }
    .tl-item:last-child { padding-bottom: 0; }
    .tl-dot { position: absolute; left: -20px; top: 12px; width: 10px; height: 10px; border-radius: 50%; border: 2px solid; }
    .tl-dot.past { border-color: var(--muted); background: var(--surface); }
    .tl-dot.live { border-color: var(--green); background: var(--green); box-shadow: 0 0 8px rgba(46,204,113,0.4); }
    .tl-dot.future { border-color: var(--gold); background: var(--surface); }
    .tl-time { font-size: 0.7rem; color: var(--muted); font-weight: 500; margin-bottom: 2px; }
    .tl-title { font-size: 0.82rem; color: var(--cream); font-weight: 500; }
    .tl-meta { font-size: 0.72rem; color: var(--muted); margin-top: 1px; }

    /* ── Recent Movies ── */
    .movie-item { display: flex; align-items: center; gap: 14px; padding: 10px 0; border-bottom: 1px solid rgba(255,255,255,0.04); }
    .movie-item:last-child { border-bottom: none; }
    .movie-poster { width: 40px; height: 56px; border-radius: 4px; background: var(--surface2); border: 1px solid var(--border); overflow: hidden; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
    .movie-poster img { width: 100%; height: 100%; object-fit: cover; }
    .movie-poster svg { width: 18px; height: 18px; color: var(--muted); opacity: 0.4; }
    .movie-info { flex: 1; min-width: 0; }
    .movie-info .title { font-size: 0.82rem; font-weight: 500; color: var(--cream); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .movie-info .meta { font-size: 0.72rem; color: var(--muted); margin-top: 2px; }
    .movie-duration { font-size: 0.72rem; color: var(--muted); background: rgba(255,255,255,0.05); padding: 2px 8px; border-radius: 3px; white-space: nowrap; }

    /* ── Empty State ── */
    .empty-state { text-align: center; padding: 40px 20px; color: var(--muted); }
    .empty-state svg { width: 36px; height: 36px; margin-bottom: 10px; opacity: 0.3; }
    .empty-state p { font-size: 0.82rem; }

    /* ── Three-column bottom ── */
    .bottom-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 20px; }
  </style>
</head>
<body>

<aside class="sidebar">
  <div class="sidebar-brand">
    <div class="brand-name">CineVillage</div>
    <div class="brand-sub">Admin Portal</div>
  </div>
  <nav class="nav">
    <div class="nav-section">Overview</div>
    <a href="/admin/dashboard" class="active">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
      Dashboard
    </a>
    <div class="nav-section">Management</div>
    <a href="/admin/chains">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 7v10c0 1.1.9 2 2 2h4v-6h8v6h4c1.1 0 2-.9 2-2V7l-10-4L2 7z"/><path d="M10 19v-6h4v6"/></svg>
      Chains
    </a>
    <a href="/admin/halls">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
      Halls
    </a>
    <a href="/admin/movies">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="2"/><line x1="7" y1="2" x2="7" y2="22"/><line x1="17" y1="2" x2="17" y2="22"/><line x1="2" y1="12" x2="22" y2="12"/></svg>
      Movies
    </a>
    <a href="/admin/screenings">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="3" y1="10" x2="21" y2="10"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="16" y1="2" x2="16" y2="6"/></svg>
      Screenings
    </a>
    <a href="/admin/bookings">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 7H4a2 2 0 00-2 2v8a2 2 0 002 2h16a2 2 0 002-2V9a2 2 0 00-2-2z"/><path d="M16 17v-2a4 4 0 00-8 0v2"/><circle cx="12" cy="11" r="2"/></svg>
      Bookings
    </a>
    <% if (user && user.role === 'admin') { %>
    <a href="/admin/staff">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
      Staff Management
    </a>
    <% } %>
  </nav>
  <div class="sidebar-footer">
    <a href="/logout" class="logout-btn">
      <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
      Sign Out
    </a>
  </div>
</aside>

<main class="main">
  <div class="topbar">
    <div class="page-title">Dashboard</div>
    <div class="topbar-right">
      <span>Welcome, <strong style="color:var(--cream)"><%= typeof user !== 'undefined' && user ? user.username : 'Manager' %></strong></span>
      <span class="badge-date"><%= new Date().toLocaleDateString('en-GB', { weekday:'short', day:'numeric', month:'short', year:'numeric' }) %></span>
    </div>
  </div>

  <div class="content">

    <!-- ═══ Greeting Banner + Quick Actions ═══ -->
    <div class="greeting-banner">
      <div class="greeting-text">
        <% const hour = new Date().getHours(); let greet = 'Good evening'; if (hour < 12) greet = 'Good morning'; else if (hour < 18) greet = 'Good afternoon'; %>
        <h2><%= greet %>, <%= typeof user !== 'undefined' && user ? user.username : 'Manager' %></h2>
        <p>You have <strong><%= todayScreenings %></strong> screening<%= todayScreenings !== 1 ? 's' : '' %> today and <strong><%= weekScreenings %></strong> this week</p>
      </div>
      <div class="quick-actions">
        <a href="/admin/movies/new" class="qa-btn">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
          New Movie
        </a>
        <a href="/admin/screenings/new" class="qa-btn">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          Schedule
        </a>
        <a href="/admin/halls/new" class="qa-btn">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/></svg>
          Add Hall
        </a>
      </div>
    </div>

    <!-- ═══ Stat Cards (6 across) ═══ -->
    <div class="stats-grid">
      <div class="stat-card green">
        <div class="stat-header">
          <div class="stat-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="2"/><line x1="7" y1="2" x2="7" y2="22"/><line x1="17" y1="2" x2="17" y2="22"/><line x1="2" y1="12" x2="22" y2="12"/></svg>
          </div>
        </div>
        <div class="stat-value"><%= activeMovies %></div>
        <div class="stat-label">Now Showing</div>
      </div>
      <div class="stat-card gold">
        <div class="stat-header">
          <div class="stat-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          </div>
        </div>
        <div class="stat-value"><%= todayScreenings %></div>
        <div class="stat-label">Screenings Today</div>
      </div>
      <div class="stat-card blue">
        <div class="stat-header">
          <div class="stat-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
          </div>
        </div>
        <div class="stat-value"><%= totalHalls %></div>
        <div class="stat-label">Active Halls</div>
      </div>
      <div class="stat-card purple">
        <div class="stat-header">
          <div class="stat-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
          </div>
        </div>
        <div class="stat-value"><%= totalMovies %></div>
        <div class="stat-label">Total Movies</div>
      </div>
      <div class="stat-card orange">
        <div class="stat-header">
          <div class="stat-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 7v10c0 1.1.9 2 2 2h4v-6h8v6h4c1.1 0 2-.9 2-2V7l-10-4L2 7z"/><path d="M10 19v-6h4v6"/></svg>
          </div>
        </div>
        <div class="stat-value"><%= totalChains %></div>
        <div class="stat-label">Active Chains</div>
      </div>
      <div class="stat-card teal">
        <div class="stat-header">
          <div class="stat-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
          </div>
        </div>
        <div class="stat-value"><%= totalStaff %></div>
        <div class="stat-label">Active Staff</div>
      </div>
    </div>

    <!-- ═══ Main Grid: Upcoming Screenings + Today's Schedule ═══ -->
    <div class="dashboard-grid">

      <!-- Left: Upcoming Screenings -->
      <div class="card">
        <div class="card-header">
          <div class="card-title">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="3" y1="10" x2="21" y2="10"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="16" y1="2" x2="16" y2="6"/></svg>
            Upcoming Screenings
          </div>
          <a href="/admin/screenings" class="btn-sm">View All</a>
        </div>
        <% if (typeof upcomingScreenings !== 'undefined' && upcomingScreenings.length > 0) { %>
          <table>
            <thead>
              <tr>
                <th>Movie</th>
                <th>Hall</th>
                <th>Date & Time</th>
                <th>Status</th>
              </tr>
            </thead>
            <tbody>
              <% upcomingScreenings.forEach(function(s) { %>
                <tr>
                  <td style="font-weight:500;"><%= s.movie ? s.movie.title : 'N/A' %></td>
                  <td>
                    <%= s.hall ? s.hall.name : 'N/A' %>
                    <% if (s.hall && s.hall.chain) { %>
                      <br><span style="font-size:0.68rem;color:var(--muted)"><%= s.hall.chain.name %></span>
                    <% } %>
                  </td>
                  <td>
                    <div><%= new Date(s.startTime).toLocaleDateString('en-GB', { day:'numeric', month:'short' }) %></div>
                    <span style="font-size:0.72rem;color:var(--muted)"><%= new Date(s.startTime).toLocaleTimeString('en-GB', { hour:'2-digit', minute:'2-digit' }) %></span>
                  </td>
                  <td>
                    <% const now2 = new Date(); const diff2 = (new Date(s.startTime) - now2) / 60000; %>
                    <% if (diff2 < 0 && diff2 > -(s.movie ? s.movie.duration : 120)) { %>
                      <span class="pill pill-live">● Now Playing</span>
                    <% } else if (diff2 < 60 && diff2 >= 0) { %>
                      <span class="pill pill-active">Starting Soon</span>
                    <% } else { %>
                      <span class="pill pill-soon">Upcoming</span>
                    <% } %>
                  </td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        <% } else { %>
          <div class="empty-state">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            <p>No upcoming screenings scheduled.</p>
          </div>
        <% } %>
      </div>

      <!-- Right: Today's Schedule Timeline -->
      <div class="card">
        <div class="card-header">
          <div class="card-title">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            Today's Schedule
          </div>
          <span style="font-size:0.72rem;color:var(--muted)"><%= todaySchedule.length %> screening<%= todaySchedule.length !== 1 ? 's' : '' %></span>
        </div>
        <div class="card-body">
          <% if (todaySchedule.length > 0) { %>
            <div class="timeline">
              <% todaySchedule.forEach(function(s) { %>
                <% const tnow = new Date(); const tstart = new Date(s.startTime); const tend = new Date(s.endTime); %>
                <% let dotClass = 'future'; if (tend <= tnow) dotClass = 'past'; else if (tstart <= tnow && tend > tnow) dotClass = 'live'; %>
                <div class="tl-item">
                  <div class="tl-dot <%= dotClass %>"></div>
                  <div class="tl-time"><%= tstart.toLocaleTimeString('en-GB', { hour:'2-digit', minute:'2-digit' }) %> — <%= tend.toLocaleTimeString('en-GB', { hour:'2-digit', minute:'2-digit' }) %></div>
                  <div class="tl-title"><%= s.movie ? s.movie.title : 'N/A' %></div>
                  <div class="tl-meta"><%= s.hall ? s.hall.name : '' %><%= s.hall && s.hall.chain ? ' · ' + s.hall.chain.name : '' %></div>
                </div>
              <% }); %>
            </div>
          <% } else { %>
            <div class="empty-state">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              <p>No screenings scheduled for today.</p>
            </div>
          <% } %>
        </div>
      </div>

    </div>

    <!-- ═══ Bottom Grid: Genre Chart + Chain Breakdown + Recent Movies ═══ -->
    <div class="bottom-grid">

      <!-- Genre Distribution -->
      <div class="card">
        <div class="card-header">
          <div class="card-title">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
            Genre Distribution
          </div>
        </div>
        <div class="card-body">
          <% if (genreBreakdown.length > 0) { %>
            <% genreBreakdown.forEach(function(g, i) { %>
              <div class="genre-row">
                <div class="genre-label"><%= g.genre %></div>
                <div class="genre-bar-wrap">
                  <div class="genre-bar genre-colors-<%= i %>" style="width: <%= Math.round((g.count / genreMax) * 100) %>%">
                    <span><%= g.count %></span>
                  </div>
                </div>
              </div>
            <% }); %>
          <% } else { %>
            <div class="empty-state"><p>No genre data yet.</p></div>
          <% } %>
        </div>
      </div>

      <!-- Chain Screenings (next 7 days) -->
      <div class="card">
        <div class="card-header">
          <div class="card-title">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 7v10c0 1.1.9 2 2 2h4v-6h8v6h4c1.1 0 2-.9 2-2V7l-10-4L2 7z"/></svg>
            Chain Activity (7 days)
          </div>
        </div>
        <div class="card-body">
          <% if (chainScreeningAgg.length > 0) { %>
            <% chainScreeningAgg.forEach(function(c) { %>
              <div class="chain-item">
                <span class="chain-name"><%= c._id %></span>
                <span class="chain-count"><%= c.count %> screening<%= c.count !== 1 ? 's' : '' %></span>
              </div>
            <% }); %>
          <% } else { %>
            <div class="empty-state"><p>No screenings this week.</p></div>
          <% } %>
        </div>
      </div>

      <!-- Recently Added Movies -->
      <div class="card">
        <div class="card-header">
          <div class="card-title">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="2"/><line x1="7" y1="2" x2="7" y2="22"/><line x1="17" y1="2" x2="17" y2="22"/><line x1="2" y1="12" x2="22" y2="12"/></svg>
            Recently Added
          </div>
          <a href="/admin/movies" class="btn-sm">All Movies</a>
        </div>
        <div class="card-body">
          <% if (recentMovies.length > 0) { %>
            <% recentMovies.forEach(function(m) { %>
              <div class="movie-item">
                <div class="movie-poster">
                  <% if (m.posterUrl) { %>
                    <img src="<%= m.posterUrl %>" alt="<%= m.title %>"/>
                  <% } else { %>
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="2" width="20" height="20" rx="2"/><circle cx="8" cy="8" r="2"/><path d="M21 15l-5-5L5 21"/></svg>
                  <% } %>
                </div>
                <div class="movie-info">
                  <div class="title"><%= m.title %></div>
                  <div class="meta"><%= m.genre || '—' %> · <%= m.rating || 'NR' %><%= m.chains && m.chains.length > 0 ? ' · ' + m.chains.map(function(c){ return c.name || c; }).join(', ') : '' %></div>
                </div>
                <span class="movie-duration"><%= m.duration %> min</span>
              </div>
            <% }); %>
          <% } else { %>
            <div class="empty-state"><p>No movies added yet.</p></div>
          <% } %>
        </div>
      </div>

    </div>

  </div>
</main>

</body>
</html>
