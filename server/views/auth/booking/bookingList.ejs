<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>CineVillage - Bookings</title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet"/>
  <style>
:root { --ink:#0a0a0f; --gold:#c9a84c; --cream:#f5f0e8; --muted:#6b6b7a; --surface:#13131a; --border:rgba(201,168,76,.15); --red:#e74c3c; }
    * { box-sizing:border-box; margin:0; padding:0; }
    body { min-height:100vh; background:var(--ink); color:var(--cream); font-family:'DM Sans',sans-serif; display:flex; }
    .sidebar {
      width: 240px;
      min-height: 100vh;
      background: var(--surface);
      border-right: 1px solid var(--border);
      display: flex;
      flex-direction: column;
      position: fixed;
      top: 0;
      left: 0;
      bottom: 0;
      z-index: 100;
    }
    .sidebar-brand { padding:28px 24px 20px; border-bottom:1px solid var(--border); }
    .brand-name { font-family:'Playfair Display',serif; font-size:1.3rem; font-weight:900; color:var(--gold); }
    .brand-sub { font-size:.7rem; color:var(--muted); letter-spacing:.15em; text-transform:uppercase; margin-top:3px; }
    .nav { flex: 1; padding:20px 12px; }
    .nav-section { font-size:.65rem; font-weight: 600; color:var(--muted); letter-spacing:.2em; text-transform:uppercase; padding:0 12px; margin-bottom: 8px; margin-top: 20px; }
    .nav-section:first-child { margin-top: 0; }
    .nav a { display:flex; align-items:center; gap:10px; padding:9px 12px; border-radius:4px; color:var(--muted); text-decoration:none; font-size:.88rem; transition: all 0.15s; margin-bottom:2px; }
    .nav a:hover { background:rgba(201,168,76,.08); color:var(--cream); }
    .nav a.active { background:rgba(201,168,76,.12); color:var(--gold); font-weight:500; }
    .nav a svg { width: 16px; height: 16px; flex-shrink: 0; }
    .sidebar-footer { padding:16px 12px; border-top:1px solid var(--border); }
    .logout-btn { display:flex; align-items:center; gap:10px; width:100%; color:var(--muted); text-decoration:none; padding:9px 12px; border-radius:4px; font-size: .88rem; }
    .logout-btn:hover { background:rgba(231,76,60,.1); color:var(--red); }
    .main { margin-left:240px; flex:1; }
    .topbar { background:var(--surface); border-bottom:1px solid var(--border); padding:16px 32px; display:flex; justify-content:space-between; }
    .page-title { font-family:'Playfair Display',serif; font-size:1.35rem; }
    .content { padding:28px 32px; }
    .table-wrap { background:var(--surface); border:1px solid var(--border); border-radius:6px; overflow:hidden; }
    table { width:100%; border-collapse:collapse; }
    th { font-size:.66rem; text-transform:uppercase; letter-spacing:.15em; color:var(--muted); text-align:left; padding:12px 16px; border-bottom:1px solid var(--border); }
    td { padding:12px 16px; border-bottom:1px solid rgba(255,255,255,.05); font-size:.82rem; vertical-align:top; }
    tr:last-child td { border-bottom:none; }
    .badge { display:inline-block; font-size:.68rem; color:var(--gold); border:1px solid var(--border); border-radius:999px; padding:2px 8px; }
    .empty { text-align:center; color:var(--muted); padding:48px 24px; }
  </style>
</head>
<body>
  <%- include('../../partials/sidebar', { activePage: 'bookings', user: user }) %>

  <main class="main">
    <div class="topbar">
      <div class="page-title">Bookings</div>
      <div style="color:var(--muted); font-size:.82rem;"><%= bookings.length %> booking<%= bookings.length !== 1 ? 's' : '' %></div>
    </div>

    <div class="content">
      <div class="table-wrap">
        <% if (bookings.length > 0) { %>
        <table>
          <thead>
            <tr>
              <th>Customer</th>
              <th>Movie</th>
              <th>Date</th>
              <th>Seats</th>
              <th>Total</th>
              <th>Code</th>
            </tr>
          </thead>
          <tbody>
            <% bookings.forEach(function(b) { %>
              <tr>
                <td>
                  <div><%= b.name %></div>
                  <div style="color:var(--muted); font-size:.72rem;"><%= b.email %></div>
                </td>
                <td>
                  <div><%= b.screening && b.screening.movie ? b.screening.movie.title : 'N/A' %></div>
                  <div style="color:var(--muted); font-size:.72rem;">
                    <%= b.screening && b.screening.hall ? b.screening.hall.name : '' %>
                    <%= b.screening && b.screening.hall && b.screening.hall.chain ? ' · ' + b.screening.hall.chain.name : '' %>
                  </div>
                </td>
                <td>
                  <% if (b.screening) { %>
                    <%= new Date(b.screening.startTime).toLocaleDateString('en-GB', { day:'numeric', month:'short', year:'numeric' }) %>
                    <div style="color:var(--muted); font-size:.72rem;"><%= new Date(b.screening.startTime).toLocaleTimeString('en-GB', { hour:'2-digit', minute:'2-digit' }) %></div>
                  <% } else { %>
                    N/A
                  <% } %>
                </td>
                <td>
                  <% if (Array.isArray(b.selectedSeats) && b.selectedSeats.length > 0) { %>
                    <span class="badge"><%= b.selectedSeats.join(', ') %></span>
                  <% } else { %>
                    <span class="badge"><%= b.seatCount %> seat<%= b.seatCount !== 1 ? 's' : '' %></span>
                  <% } %>
                </td>
                <td>SGD <%= Number(b.totalPrice || 0).toFixed(2) %></td>
                <td><%= b.confirmationCode %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
        <% } else { %>
          <div class="empty">No bookings have been made yet.</div>
        <% } %>
      </div>
    </div>
  </main>
</body>
</html>
