<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>CineVillage — <%= chain.name %></title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet"/>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --ink: #0a0a0f;
      --gold: #c9a84c;
      --gold-light: #e8c87a;
      --cream: #f5f0e8;
      --muted: #6b6b7a;
      --surface: #13131a;
      --surface2: #1c1c27;
      --border: rgba(201,168,76,0.15);
      --green: #2ecc71;
      --red: #e74c3c;
      --blue: #3498db;
      --yellow: #f1c40f;
    }

    body { min-height: 100vh; background: var(--ink); font-family: 'DM Sans', sans-serif; color: var(--cream); display: flex; }

    .sidebar { width: 240px; min-height: 100vh; background: var(--surface); border-right: 1px solid var(--border); display: flex; flex-direction: column; position: fixed; top: 0; left: 0; bottom: 0; z-index: 100; }
    .sidebar-brand { padding: 28px 24px 20px; border-bottom: 1px solid var(--border); }
    .brand-name { font-family: 'Playfair Display', serif; font-size: 1.3rem; font-weight: 900; color: var(--gold); }
    .brand-sub { font-size: 0.7rem; color: var(--muted); letter-spacing: 0.15em; text-transform: uppercase; margin-top: 3px; }

    .nav { flex: 1; padding: 20px 12px; }
    .nav-section { font-size: 0.65rem; font-weight: 600; color: var(--muted); letter-spacing: 0.2em; text-transform: uppercase; padding: 0 12px; margin-bottom: 8px; margin-top: 20px; }
    .nav-section:first-child { margin-top: 0; }
    .nav a { display: flex; align-items: center; gap: 10px; padding: 9px 12px; border-radius: 4px; color: var(--muted); text-decoration: none; font-size: 0.88rem; transition: all 0.15s; margin-bottom: 2px; }
    .nav a:hover { background: rgba(201,168,76,0.08); color: var(--cream); }
    .nav a.active { background: rgba(201,168,76,0.12); color: var(--gold); font-weight: 500; }
    .nav a svg { width: 16px; height: 16px; flex-shrink: 0; }

    .sidebar-footer { padding: 16px 12px; border-top: 1px solid var(--border); }
    .logout-btn { display: flex; align-items: center; gap: 10px; width: 100%; padding: 9px 12px; border-radius: 4px; background: none; border: none; color: var(--muted); font-family: 'DM Sans', sans-serif; font-size: 0.88rem; cursor: pointer; text-decoration: none; transition: all 0.15s; }
    .logout-btn:hover { background: rgba(231,76,60,0.1); color: #e74c3c; }

    .main { margin-left: 240px; flex: 1; display: flex; flex-direction: column; min-height: 100vh; }
    .topbar { background: var(--surface); border-bottom: 1px solid var(--border); padding: 16px 32px; display: flex; align-items: center; justify-content: space-between; }
    .page-title { font-family: 'Playfair Display', serif; font-size: 1.4rem; font-weight: 700; color: var(--cream); }
    .breadcrumb { font-size: 0.8rem; color: var(--muted); display: flex; align-items: center; gap: 8px; }
    .breadcrumb a { color: var(--gold); text-decoration: none; }
    .content { padding: 32px; flex: 1; }

    /* ── Info Header ── */
    .chain-header {
      background: var(--surface); border: 1px solid var(--border); border-radius: 4px;
      padding: 24px 28px; margin-bottom: 24px; display: flex; align-items: flex-start;
      justify-content: space-between; gap: 20px;
    }

    .chain-info h2 { font-family: 'Playfair Display', serif; font-size: 1.3rem; font-weight: 900; color: var(--gold); margin-bottom: 6px; }
    .chain-meta { display: flex; flex-wrap: wrap; gap: 16px; margin-top: 10px; }
    .meta-item { display: flex; align-items: center; gap: 6px; font-size: 0.82rem; color: var(--muted); }
    .meta-item svg { width: 14px; height: 14px; }

    .pill { display: inline-block; padding: 3px 10px; border-radius: 20px; font-size: 0.72rem; font-weight: 500; }
    .pill-active { background: rgba(46,204,113,0.12); color: var(--green); }
    .pill-closed { background: rgba(107,107,122,0.15); color: var(--muted); }
    .pill-coming { background: rgba(52,152,219,0.12); color: var(--blue); }

    .chain-actions { display: flex; gap: 8px; flex-shrink: 0; }
    .btn-sm {
      display: inline-flex; align-items: center; gap: 5px; padding: 7px 14px;
      border-radius: 3px; font-family: 'DM Sans', sans-serif; font-size: 0.78rem;
      font-weight: 500; text-decoration: none; border: 1px solid; cursor: pointer;
      background: none; transition: all 0.15s;
    }
    .btn-sm svg { width: 13px; height: 13px; }
    .btn-sm-edit { border-color: rgba(201,168,76,0.3); color: var(--gold); }
    .btn-sm-edit:hover { background: rgba(201,168,76,0.1); }

    /* ── Stats ── */
    .stats-row { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-bottom: 28px; }
    .stat-card {
      background: var(--surface); border: 1px solid var(--border); border-radius: 4px;
      padding: 20px; text-align: center;
    }
    .stat-val { font-family: 'Playfair Display', serif; font-size: 2rem; font-weight: 900; color: var(--gold); }
    .stat-label { font-size: 0.72rem; color: var(--muted); letter-spacing: 0.15em; text-transform: uppercase; margin-top: 4px; }

    /* ── Section Titles ── */
    .section-title {
      font-family: 'Playfair Display', serif; font-size: 1.1rem; font-weight: 700;
      color: var(--cream); margin-bottom: 16px; display: flex; align-items: center; gap: 10px;
    }
    .section-title svg { width: 18px; height: 18px; color: var(--gold); }

    /* ── Table ── */
    .table-wrap { background: var(--surface); border: 1px solid var(--border); border-radius: 4px; overflow: hidden; margin-bottom: 32px; }
    table { width: 100%; border-collapse: collapse; }
    thead th {
      padding: 12px 16px; font-size: 0.7rem; font-weight: 600; color: var(--muted);
      letter-spacing: 0.15em; text-transform: uppercase; text-align: left;
      border-bottom: 1px solid var(--border); background: rgba(255,255,255,0.02);
    }
    tbody tr { border-bottom: 1px solid rgba(255,255,255,0.04); transition: background 0.15s; }
    tbody tr:last-child { border-bottom: none; }
    tbody tr:hover { background: rgba(201,168,76,0.04); }
    tbody td { padding: 13px 16px; font-size: 0.87rem; color: var(--cream); vertical-align: middle; }

    .hall-name { font-weight: 500; }

    .pill-type { background: rgba(201,168,76,0.1); color: var(--gold); }
    .pill-maint { background: rgba(241,196,15,0.12); color: #f1c40f; }

    /* ── Movie Cards ── */
    .movie-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 16px; margin-bottom: 32px; }
    .movie-card {
      background: var(--surface); border: 1px solid var(--border); border-radius: 4px;
      padding: 18px; transition: border-color 0.2s;
    }
    .movie-card:hover { border-color: var(--gold); }
    .movie-card h4 { font-family: 'Playfair Display', serif; font-size: 0.95rem; font-weight: 700; color: var(--cream); margin-bottom: 8px; }
    .movie-card-meta { font-size: 0.78rem; color: var(--muted); display: flex; flex-direction: column; gap: 4px; }
    .movie-card-meta span { display: flex; align-items: center; gap: 5px; }
    .movie-card-meta svg { width: 12px; height: 12px; }

    /* ── Screenings ── */
    .screening-item {
      display: flex; align-items: center; gap: 16px; padding: 12px 16px;
      border-bottom: 1px solid rgba(255,255,255,0.04); transition: background 0.15s;
    }
    .screening-item:last-child { border-bottom: none; }
    .screening-item:hover { background: rgba(201,168,76,0.04); }
    .screening-time {
      font-family: 'Playfair Display', serif; font-size: 0.95rem; font-weight: 700;
      color: var(--gold); min-width: 140px;
    }
    .screening-date { font-size: 0.75rem; color: var(--muted); }
    .screening-details { flex: 1; }
    .screening-movie { font-weight: 500; font-size: 0.88rem; }
    .screening-hall { font-size: 0.78rem; color: var(--muted); margin-top: 2px; }

    .empty-message { padding: 32px; text-align: center; color: var(--muted); font-size: 0.85rem; }
  </style>
</head>
<body>

<aside class="sidebar">
  <div class="sidebar-brand">
    <div class="brand-name">CineVillage</div>
    <div class="brand-sub">Admin Portal</div>
  </div>
  <nav class="nav">
    <div class="nav-section">Overview</div>
    <a href="/admin/dashboard"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>Dashboard</a>
    <div class="nav-section">Management</div>
    <a href="/admin/chains" class="active"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 7v10c0 1.1.9 2 2 2h4v-6h8v6h4c1.1 0 2-.9 2-2V7l-10-4L2 7z"/><path d="M10 19v-6h4v6"/></svg>Chains</a>
    <a href="/admin/halls"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>Halls</a>
    <a href="/admin/movies"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="2"/><line x1="7" y1="2" x2="7" y2="22"/><line x1="17" y1="2" x2="17" y2="22"/><line x1="2" y1="12" x2="22" y2="12"/></svg>Movies</a>
    <a href="/admin/screenings"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="3" y1="10" x2="21" y2="10"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="16" y1="2" x2="16" y2="6"/></svg>Screenings</a>
    <% if (user && user.role === 'admin') { %>
    <a href="/admin/staff"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>Staff Management</a>
    <% } %>
  </nav>
  <div class="sidebar-footer">
    <a href="/logout" class="logout-btn"><svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>Sign Out</a>
  </div>
</aside>

<main class="main">
  <div class="topbar">
    <div class="page-title"><%= chain.name %></div>
    <div class="breadcrumb">
      <a href="/admin/chains">Chains</a>
      <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
      <span><%= chain.name %></span>
    </div>
  </div>

  <div class="content">
    <% if (success && success.length > 0) { %>
      <div style="padding:10px 16px; border-radius:3px; font-size:0.85rem; margin-bottom:20px; border-left:3px solid var(--green); background:rgba(46,204,113,0.1); color:#7deba0;"><%= success[0] %></div>
    <% } %>

    <!-- Chain Header -->
    <div class="chain-header">
      <div class="chain-info">
        <h2><%= chain.name %></h2>
        <% if (chain.status === 'Active') { %>
          <span class="pill pill-active">Active</span>
        <% } else if (chain.status === 'Closed') { %>
          <span class="pill pill-closed">Closed</span>
        <% } else { %>
          <span class="pill pill-coming">Coming Soon</span>
        <% } %>
        <div class="chain-meta">
          <div class="meta-item">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
            <%= chain.location %>
          </div>
          <% if (chain.contactNumber) { %>
          <div class="meta-item">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
            <%= chain.contactNumber %>
          </div>
          <% } %>
          <% if (chain.email) { %>
          <div class="meta-item">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            <%= chain.email %>
          </div>
          <% } %>
        </div>
        <% if (chain.description) { %>
          <p style="margin-top:12px; font-size:0.85rem; color:var(--muted); line-height:1.5;"><%= chain.description %></p>
        <% } %>
      </div>
      <div class="chain-actions">
        <a href="/admin/chains/<%= chain._id %>/edit" class="btn-sm btn-sm-edit">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
          Edit Chain
        </a>
      </div>
    </div>

    <!-- Stats -->
    <div class="stats-row">
      <div class="stat-card">
        <div class="stat-val"><%= halls.length %></div>
        <div class="stat-label">Total Halls</div>
      </div>
      <div class="stat-card">
        <div class="stat-val"><%= currentMovies.length %></div>
        <div class="stat-label">Movies Showing</div>
      </div>
      <div class="stat-card">
        <div class="stat-val"><%= screenings.length %></div>
        <div class="stat-label">Upcoming Screenings</div>
      </div>
    </div>

    <!-- Halls -->
    <div class="section-title">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
      Halls in this Chain
    </div>

    <div class="table-wrap">
      <% if (halls.length > 0) { %>
        <table>
          <thead>
            <tr>
              <th>Name</th>
              <th>Type</th>
              <th>Capacity</th>
              <th>Status</th>
            </tr>
          </thead>
          <tbody>
            <% halls.forEach(function(hall) { %>
              <tr>
                <td class="hall-name"><%= hall.name %></td>
                <td><span class="pill pill-type"><%= hall.hallType || 'Standard' %></span></td>
                <td><%= hall.rows * hall.columns %> seats</td>
                <td>
                  <% if (hall.status === 'Active') { %>
                    <span class="pill pill-active">Active</span>
                  <% } else if (hall.status === 'Under Maintenance') { %>
                    <span class="pill pill-maint">Maintenance</span>
                  <% } else { %>
                    <span class="pill pill-closed">Closed</span>
                  <% } %>
                </td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      <% } else { %>
        <div class="empty-message">No halls assigned to this chain yet. <a href="/admin/halls/new" style="color:var(--gold);">Add a hall</a></div>
      <% } %>
    </div>

    <!-- Movies Currently Showing -->
    <div class="section-title">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="2"/><line x1="7" y1="2" x2="7" y2="22"/><line x1="17" y1="2" x2="17" y2="22"/><line x1="2" y1="12" x2="22" y2="12"/></svg>
      Movies Currently Showing
    </div>

    <% if (currentMovies.length > 0) { %>
      <div class="movie-grid">
        <% currentMovies.forEach(function(movie) { %>
          <div class="movie-card">
            <h4><%= movie.title %></h4>
            <div class="movie-card-meta">
              <% if (movie.genre) { %>
              <span>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                <%= movie.genre %>
              </span>
              <% } %>
              <span>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                <%= movie.duration %> min
              </span>
              <% if (movie.rating) { %>
              <span>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="4" width="20" height="16" rx="2"/><line x1="2" y1="8" x2="22" y2="8"/></svg>
                <%= movie.rating %>
              </span>
              <% } %>
            </div>
          </div>
        <% }); %>
      </div>
    <% } else { %>
      <div class="table-wrap">
        <div class="empty-message">No movies currently scheduled at this chain.</div>
      </div>
    <% } %>

    <!-- Upcoming Screenings -->
    <div class="section-title" style="margin-top:8px;">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="3" y1="10" x2="21" y2="10"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="16" y1="2" x2="16" y2="6"/></svg>
      Upcoming Screenings
    </div>

    <div class="table-wrap">
      <% if (screenings.length > 0) { %>
        <% screenings.forEach(function(s) { %>
          <div class="screening-item">
            <div>
              <div class="screening-time">
                <%= new Date(s.startTime).toLocaleTimeString('en-SG', { hour: '2-digit', minute: '2-digit', hour12: true }) %>
              </div>
              <div class="screening-date">
                <%= new Date(s.startTime).toLocaleDateString('en-SG', { weekday: 'short', day: 'numeric', month: 'short' }) %>
              </div>
            </div>
            <div class="screening-details">
              <div class="screening-movie"><%= s.movie ? s.movie.title : 'Unknown Movie' %></div>
              <div class="screening-hall"><%= s.hall ? s.hall.name : 'Unknown Hall' %> · <%= s.hall ? s.hall.hallType : '' %></div>
            </div>
            <div>
              <span class="pill pill-type" style="font-size:0.7rem;">
                <%= new Date(s.startTime).toLocaleTimeString('en-SG', { hour: '2-digit', minute: '2-digit', hour12: true }) %> –
                <%= new Date(s.endTime).toLocaleTimeString('en-SG', { hour: '2-digit', minute: '2-digit', hour12: true }) %>
              </span>
            </div>
          </div>
        <% }); %>
      <% } else { %>
        <div class="empty-message">No upcoming screenings at this chain.</div>
      <% } %>
    </div>
  </div>
</main>
</body>
</html>
