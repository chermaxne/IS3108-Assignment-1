<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>CineVillage - Screening Seats</title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet"/>
  <style>
:root { --ink:#0a0a0f; --gold:#c9a84c; --cream:#f5f0e8; --muted:#6b6b7a; --surface:#13131a; --border:rgba(201,168,76,.15); --sold:#e74c3c; --free:#2ecc71; }
    * { box-sizing:border-box; margin:0; padding:0; }
    body { min-height:100vh; background:var(--ink); color:var(--cream); font-family:'DM Sans',sans-serif; }
    .container { max-width:1200px; margin:0 auto; padding:24px; }
    h1 { font-family:'Playfair Display',serif; color:var(--gold); margin-bottom:6px; }
    .meta { color:var(--muted); margin-bottom:18px; }
    .stats { display:flex; gap:10px; margin-bottom:18px; flex-wrap:wrap; }
    .pill { border:1px solid var(--border); border-radius:999px; padding:4px 12px; font-size:.78rem; }
    .layout-wrap { background:var(--surface); border:1px solid var(--border); border-radius:8px; padding:18px; margin-bottom:20px; }
    .screen { text-align:center; color:var(--muted); margin-bottom:14px; letter-spacing:.18em; font-size:.72rem; }
    .seat-grid { display:grid; gap:6px; }
    .seat-row { display:grid; grid-template-columns: repeat(auto-fit, minmax(38px, 38px)); gap:6px; justify-content:center; }
    .seat { border-radius:4px; text-align:center; font-size:.68rem; padding:7px 0; border:1px solid var(--border); }
    .seat.gap { background:transparent; border:1px dashed rgba(255,255,255,.08); color:transparent; }
    .seat.sold { background:rgba(231,76,60,.18); color:#ffb3ab; border-color:rgba(231,76,60,.45); }
    .seat.free { background:rgba(46,204,113,.14); color:#b7f1cb; border-color:rgba(46,204,113,.4); }
    .legend { margin-top:12px; display:flex; gap:14px; justify-content:center; color:var(--muted); font-size:.78rem; }
    .booking-table { background:var(--surface); border:1px solid var(--border); border-radius:8px; overflow:hidden; }
    table { width:100%; border-collapse:collapse; }
    th { color:var(--muted); text-transform:uppercase; letter-spacing:.14em; font-size:.65rem; text-align:left; padding:11px 14px; border-bottom:1px solid var(--border); }
    td { padding:11px 14px; font-size:.82rem; border-bottom:1px solid rgba(255,255,255,.05); }
    tr:last-child td { border-bottom:none; }
    .empty { color:var(--muted); padding:28px; text-align:center; }
    .back { display:inline-block; margin-top:16px; color:var(--gold); text-decoration:none; }
  </style>
</head>
<body>
  <div class="container">
    <h1>Seat Visualisation</h1>
    <p class="meta">
      <%= screening.movie ? screening.movie.title : 'N/A' %> ·
      <%= screening.hall ? screening.hall.name : '' %>
      <%= screening.hall && screening.hall.chain ? ' (' + screening.hall.chain.name + ')' : '' %> ·
      <%= new Date(screening.startTime).toLocaleString('en-GB', { day:'numeric', month:'short', year:'numeric', hour:'2-digit', minute:'2-digit' }) %>
    </p>

    <div class="stats">
      <span class="pill">Capacity: <strong><%= capacity %></strong></span>
      <span class="pill">Sold: <strong><%= soldSeatsCount %></strong></span>
      <span class="pill">Available: <strong><%= availableSeatsCount %></strong></span>
      <span class="pill">Bookings: <strong><%= bookings.length %></strong></span>
    </div>

    <div class="layout-wrap">
      <div class="screen">SCREEN</div>
      <div class="seat-grid">
        <% seatGrid.forEach(function(row){ %>
          <div class="seat-row">
            <% row.forEach(function(seat){ %>
              <% if (seat.isGap) { %>
                <div class="seat gap" aria-hidden="true"></div>
              <% } else { %>
                <div class="seat <%= seat.sold ? 'sold' : 'free' %>"><%= seat.label %></div>
              <% } %>
            <% }) %>
          </div>
        <% }) %>
      </div>
      <div class="legend">
        <span><strong style="color:var(--sold)">■</strong> Sold</span>
        <span><strong style="color:var(--free)">■</strong> Available</span>
      </div>
    </div>

    <div class="booking-table">
      <% if (bookings.length > 0) { %>
        <table>
          <thead>
            <tr>
              <th>Customer</th>
              <th>Seats</th>
              <th>Total</th>
              <th>Booked At</th>
              <th>Code</th>
            </tr>
          </thead>
          <tbody>
            <% bookings.forEach(function(b){ %>
              <tr>
                <td>
                  <%= b.name %>
                  <div style="font-size:.72rem;color:var(--muted)"><%= b.email %></div>
                </td>
                <td>
                  <% if (Array.isArray(b.selectedSeats) && b.selectedSeats.length > 0) { %>
                    <%= b.selectedSeats.join(', ') %>
                  <% } else { %>
                    <%= b.seatCount %> seat<%= b.seatCount !== 1 ? 's' : '' %>
                  <% } %>
                </td>
                <td>SGD <%= Number(b.totalPrice || 0).toFixed(2) %></td>
                <td><%= new Date(b.createdAt).toLocaleString('en-GB', { day:'numeric', month:'short', year:'numeric', hour:'2-digit', minute:'2-digit' }) %></td>
                <td><%= b.confirmationCode %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } else { %>
        <div class="empty">No bookings for this screening yet.</div>
      <% } %>
    </div>

    <a class="back" href="/admin/screenings">← Back to Screenings</a>
  </div>
</body>
</html>
