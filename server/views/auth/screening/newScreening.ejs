<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>CineVillage — Schedule Screening</title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet"/>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --ink: #0a0a0f;
      --gold: #c9a84c;
      --gold-light: #e8c87a;
      --cream: #f5f0e8;
      --muted: #6b6b7a;
      --surface: #13131a;
      --border: rgba(201,168,76,0.15);
      --green: #2ecc71;
      --red: #e74c3c;
      --blue: #3498db;
    }

    body {
      min-height: 100vh;
      background: var(--ink);
      font-family: 'DM Sans', sans-serif;
      color: var(--cream);
      display: flex;
    }

    /* ── Sidebar ── */
    .sidebar {
      width: 240px;
      min-height: 100vh;
      background: var(--surface);
      border-right: 1px solid var(--border);
      display: flex;
      flex-direction: column;
      position: fixed;
      top: 0; left: 0; bottom: 0;
      z-index: 100;
    }

    .sidebar-brand {
      padding: 28px 24px 20px;
      border-bottom: 1px solid var(--border);
    }

    .brand-name {
      font-family: 'Playfair Display', serif;
      font-size: 1.3rem;
      font-weight: 900;
      color: var(--gold);
    }

    .brand-sub {
      font-size: 0.7rem;
      color: var(--muted);
      letter-spacing: 0.15em;
      text-transform: uppercase;
      margin-top: 3px;
    }

    .nav { flex: 1; padding: 20px 12px; }

    .nav-section {
      font-size: 0.65rem;
      font-weight: 600;
      color: var(--muted);
      letter-spacing: 0.2em;
      text-transform: uppercase;
      padding: 0 12px;
      margin-bottom: 8px;
      margin-top: 20px;
    }

    .nav-section:first-child { margin-top: 0; }

    .nav a {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 9px 12px;
      border-radius: 4px;
      color: var(--muted);
      text-decoration: none;
      font-size: 0.88rem;
      transition: all 0.15s;
      margin-bottom: 2px;
    }

    .nav a:hover { background: rgba(201,168,76,0.08); color: var(--cream); }
    .nav a.active { background: rgba(201,168,76,0.12); color: var(--gold); font-weight: 500; }
    .nav a svg { width: 16px; height: 16px; flex-shrink: 0; }

    .sidebar-footer {
      padding: 16px 12px;
      border-top: 1px solid var(--border);
    }

    .logout-btn {
      display: flex;
      align-items: center;
      gap: 10px;
      width: 100%;
      padding: 9px 12px;
      border-radius: 4px;
      background: none;
      border: none;
      color: var(--muted);
      font-family: 'DM Sans', sans-serif;
      font-size: 0.88rem;
      cursor: pointer;
      text-decoration: none;
      transition: all 0.15s;
    }

    .logout-btn:hover { background: rgba(231,76,60,0.1); color: #e74c3c; }

    /* ── Main ── */
    .main {
      margin-left: 240px;
      flex: 1;
      display: flex;
      flex-direction: column;
      min-height: 100vh;
    }

    .topbar {
      background: var(--surface);
      border-bottom: 1px solid var(--border);
      padding: 16px 32px;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .page-title {
      font-family: 'Playfair Display', serif;
      font-size: 1.4rem;
      font-weight: 700;
      color: var(--cream);
    }

    .breadcrumb {
      font-size: 0.8rem;
      color: var(--muted);
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .breadcrumb a { color: var(--gold); text-decoration: none; }

    .content {
      padding: 32px;
      flex: 1;
      display: grid;
      grid-template-columns: 1fr 320px;
      gap: 24px;
      align-items: start;
    }

    /* ── Form Card ── */
    .form-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 4px;
      overflow: hidden;
    }

    .form-card-header {
      padding: 20px 28px;
      border-bottom: 1px solid var(--border);
      background: rgba(255,255,255,0.02);
    }

    .form-card-title {
      font-family: 'Playfair Display', serif;
      font-size: 1.05rem;
      font-weight: 700;
      color: var(--cream);
    }

    .form-card-body { padding: 28px; }

    .form-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 20px;
    }

    .field { display: flex; flex-direction: column; gap: 7px; }
    .field.full { grid-column: 1 / -1; }

    .field label {
      font-size: 0.73rem;
      font-weight: 600;
      color: var(--muted);
      letter-spacing: 0.12em;
      text-transform: uppercase;
    }

    .field input,
    .field select {
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.1);
      border-radius: 3px;
      padding: 10px 13px;
      color: var(--cream);
      font-family: 'DM Sans', sans-serif;
      font-size: 0.9rem;
      outline: none;
      transition: border-color 0.2s;
    }

    .field input:focus,
    .field select:focus {
      border-color: var(--gold);
      background: rgba(201,168,76,0.04);
    }

    .field select option { background: #1c1c27; }
    .field-hint { font-size: 0.73rem; color: var(--muted); }

    /* ── Alert ── */
    .alert {
      padding: 12px 16px;
      border-radius: 3px;
      font-size: 0.85rem;
      margin-bottom: 20px;
      border-left: 3px solid;
    }

    .alert-error {
      background: rgba(231,76,60,0.1);
      border-color: var(--red);
      color: #f1948a;
    }

    .alert-warning {
      background: rgba(201,168,76,0.08);
      border-color: var(--gold);
      color: var(--gold-light);
    }

    /* ── Form Actions ── */
    .form-actions {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 20px 28px;
      border-top: 1px solid var(--border);
    }

    .btn-primary {
      display: inline-flex;
      align-items: center;
      gap: 7px;
      padding: 10px 22px;
      background: var(--gold);
      border: none;
      border-radius: 3px;
      color: var(--ink);
      font-family: 'DM Sans', sans-serif;
      font-size: 0.83rem;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      cursor: pointer;
      transition: background 0.2s;
      text-decoration: none;
    }

    .btn-primary:hover { background: var(--gold-light); }

    .btn-secondary {
      display: inline-flex;
      align-items: center;
      padding: 10px 18px;
      border: 1px solid var(--border);
      border-radius: 3px;
      color: var(--muted);
      font-family: 'DM Sans', sans-serif;
      font-size: 0.83rem;
      text-decoration: none;
      transition: all 0.15s;
    }

    .btn-secondary:hover { border-color: var(--gold); color: var(--gold); }

    .divider { height: 1px; background: var(--border); grid-column: 1 / -1; }

    .section-label {
      font-family: 'Playfair Display', serif;
      font-size: 0.9rem;
      color: var(--gold);
      font-weight: 700;
      grid-column: 1 / -1;
      margin-top: 4px;
    }

    /* ── Summary Panel ── */
    .summary-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 4px;
      overflow: hidden;
      position: sticky;
      top: 24px;
    }

    .summary-header {
      padding: 16px 20px;
      border-bottom: 1px solid var(--border);
      background: rgba(255,255,255,0.02);
    }

    .summary-title {
      font-family: 'Playfair Display', serif;
      font-size: 0.95rem;
      color: var(--cream);
      font-weight: 700;
    }

    .summary-body { padding: 20px; }

    .timeline-bar {
      position: relative;
      height: 40px;
      background: rgba(255,255,255,0.04);
      border-radius: 4px;
      overflow: hidden;
      margin: 16px 0;
    }

    .timeline-fill {
      position: absolute;
      top: 0; bottom: 0;
      background: rgba(201,168,76,0.25);
      border: 1px solid rgba(201,168,76,0.4);
      border-radius: 3px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 0.7rem;
      color: var(--gold);
      font-weight: 600;
      min-width: 4px;
      transition: all 0.3s;
    }

    .detail-row {
      display: flex;
      justify-content: space-between;
      padding: 8px 0;
      border-bottom: 1px solid rgba(255,255,255,0.05);
      font-size: 0.83rem;
    }

    .detail-row:last-child { border-bottom: none; }

    .detail-label { color: var(--muted); }

    .detail-value {
      color: var(--cream);
      font-weight: 500;
      text-align: right;
    }

    .end-time-display {
      background: rgba(46,204,113,0.08);
      border: 1px solid rgba(46,204,113,0.2);
      border-radius: 4px;
      padding: 12px 14px;
      text-align: center;
      margin-top: 12px;
    }

    .end-time-label {
      font-size: 0.7rem;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: 0.12em;
      margin-bottom: 4px;
    }

    .end-time-value {
      font-family: 'Playfair Display', serif;
      font-size: 1.3rem;
      font-weight: 900;
      color: var(--green);
    }

    .overlap-warning {
      background: rgba(231,76,60,0.1);
      border: 1px solid rgba(231,76,60,0.3);
      border-radius: 4px;
      padding: 12px 14px;
      margin-top: 12px;
      font-size: 0.8rem;
      color: #f1948a;
      display: none;
    }

    .overlap-warning.visible { display: block; }

    .maint-warning {
      background: rgba(201,168,76,0.08);
      border: 1px solid rgba(201,168,76,0.3);
      border-radius: 4px;
      padding: 10px 14px;
      margin-top: 10px;
      font-size: 0.78rem;
      color: var(--gold-light);
      display: none;
    }

    .maint-warning.visible { display: block; }
  </style>
</head>
<body>

<aside class="sidebar">
  <div class="sidebar-brand">
    <div class="brand-name">CineVillage</div>
    <div class="brand-sub">Admin Portal</div>
  </div>
  <nav class="nav">
    <div class="nav-section">Overview</div>
    <a href="/admin/dashboard"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>Dashboard</a>
    <div class="nav-section">Management</div>
    <a href="/admin/chains"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 7v10c0 1.1.9 2 2 2h4v-6h8v6h4c1.1 0 2-.9 2-2V7l-10-4L2 7z"/><path d="M10 19v-6h4v6"/></svg>Chains</a>
    <a href="/admin/halls"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>Halls</a>
    <a href="/admin/movies"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="2"/><line x1="7" y1="2" x2="7" y2="22"/><line x1="17" y1="2" x2="17" y2="22"/><line x1="2" y1="12" x2="22" y2="12"/></svg>Movies</a>
    <a href="/admin/screenings" class="active"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="3" y1="10" x2="21" y2="10"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="16" y1="2" x2="16" y2="6"/></svg>Screenings</a>
    <a href="/admin/bookings"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 7H4a2 2 0 00-2 2v8a2 2 0 002 2h16a2 2 0 002-2V9a2 2 0 00-2-2z"/><path d="M16 17v-2a4 4 0 00-8 0v2"/><circle cx="12" cy="11" r="2"/></svg>Bookings</a>
    <% if (user && user.role === 'admin') { %>
    <a href="/admin/staff"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>Staff Management</a>
    <% } %>
  </nav>
  <div class="sidebar-footer">
    <a href="/logout" class="logout-btn"><svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>Sign Out</a>
  </div>
</aside>

<main class="main">
  <div class="topbar">
    <div class="page-title">Schedule Screening</div>
    <div class="breadcrumb">
      <a href="/admin/screenings">Screenings</a>
      <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
      <span>New</span>
    </div>
  </div>

  <div class="content">
    <div>
      <% if (error && error.length > 0) { %>
        <div class="alert alert-error"><%= error[0] %></div>
      <% } %>

      <div class="form-card">
        <div class="form-card-header">
          <div class="form-card-title">Screening Details</div>
        </div>

        <form method="POST" action="/admin/screenings" id="screeningForm">
          <div class="form-card-body">
            <div class="form-grid">

              <div class="section-label">Assignment</div>

              <div class="field full">
                <label for="movieId">Movie <span style="color:var(--red)">*</span></label>
                <select id="movieId" name="movieId" required onchange="filterLocations()">
                  <option value="">— Select a Movie —</option>
                  <% if (typeof movies !== 'undefined') { %>
                    <% movies.forEach(function(m) { %>
                      <option value="<%= m._id %>"
                        data-duration="<%= m.duration %>"
                        <%= (typeof formData !== 'undefined' && formData.movieId == m._id) ? 'selected' : '' %>>
                        <%= m.title %> (<%= m.duration %> min)
                      </option>
                    <% }); %>
                  <% } %>
                </select>
              </div>

              <div class="field full">
                <label for="chainId">Location <span style="color:var(--red)">*</span></label>
                <select id="chainId" onchange="filterHalls()" disabled>
                  <option value="">— Select a Movie first —</option>
                </select>
                <span class="field-hint" id="chainHint">Choose a movie above to see available locations.</span>
              </div>

              <div class="field full">
                <label for="hallId">Hall <span style="color:var(--red)">*</span></label>
                <select id="hallId" name="hallId" required onchange="updateSummary()" disabled>
                  <option value="">— Select a Location first —</option>
                </select>
                <span class="field-hint" id="hallHint">Choose a location above to see available halls.</span>
              </div>

              <div class="divider"></div>
              <div class="section-label">Schedule</div>

              <div class="field">
                <label for="screeningDate">Date <span style="color:var(--red)">*</span></label>
                <input type="date" id="screeningDate" name="screeningDate" required
                  min="<%= new Date().toISOString().split('T')[0] %>"
                  value="<%= typeof formData !== 'undefined' ? formData.screeningDate || '' : '' %>"
                  onchange="updateSummary()"/>
              </div>

              <div class="field">
                <label for="startTime">Start Time <span style="color:var(--red)">*</span></label>
                <input type="time" id="startTime" name="startTime" required
                  value="<%= typeof formData !== 'undefined' ? formData.startTime || '' : '' %>"
                  onchange="updateSummary()"/>
              </div>

              <div class="field full">
                <label for="basePrice">Base Ticket Price (SGD)</label>
                <input type="number" id="basePrice" name="basePrice" min="0" step="0.50" placeholder="e.g. 14.00"
                  value="<%= typeof formData !== 'undefined' ? formData.basePrice || '' : '' %>"/>
                <span class="field-hint">Optional. Can be used for the customer-facing app.</span>
              </div>

            </div>
          </div>
          <div class="form-actions">
            <button type="submit" class="btn-primary" id="submitBtn">
              <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
              Confirm Screening
            </button>
            <a href="/admin/screenings" class="btn-secondary">Cancel</a>
          </div>
        </form>
      </div>
    </div>

    <!-- Summary Panel -->
    <div class="summary-card">
      <div class="summary-header">
        <div class="summary-title">Screening Summary</div>
      </div>
      <div class="summary-body">
        <div class="detail-row"><span class="detail-label">Movie</span><span class="detail-value" id="sumMovie">—</span></div>
        <div class="detail-row"><span class="detail-label">Hall</span><span class="detail-value" id="sumHall">—</span></div>
        <div class="detail-row"><span class="detail-label">Chain</span><span class="detail-value" id="sumChain">—</span></div>
        <div class="detail-row"><span class="detail-label">Location</span><span class="detail-value" id="sumLocation">—</span></div>
        <div class="detail-row"><span class="detail-label">Date</span><span class="detail-value" id="sumDate">—</span></div>
        <div class="detail-row"><span class="detail-label">Start</span><span class="detail-value" id="sumStart">—</span></div>
        <div class="detail-row"><span class="detail-label">Duration</span><span class="detail-value" id="sumDuration">—</span></div>

        <div class="end-time-display" id="endTimeBox" style="display:none">
          <div class="end-time-label">Estimated End Time</div>
          <div class="end-time-value" id="endTimeVal">—</div>
        </div>

        <div class="maint-warning" id="maintWarn">
          ⚠ This hall is currently under maintenance. New screenings cannot be scheduled.
        </div>

        <div class="overlap-warning" id="overlapWarn">
          ⛔ Server will check for booking conflicts at submission. Ensure no other screening is active in the selected hall during this time window.
        </div>
      </div>
    </div>
  </div>
</main>

<script>
  // Cascade data pre-built by controller (all IDs are already strings)
  const allHalls = <%- JSON.stringify(hallList) %>;
  const allChains = <%- JSON.stringify(chainList) %>;
  const movieChainMap = <%- JSON.stringify(movieChainMap) %>;

  // Movie selected → filter Location dropdown to only show chains assigned to that movie
  function filterLocations() {
    const movieSel = document.getElementById('movieId');
    const chainSel = document.getElementById('chainId');
    const chainHint = document.getElementById('chainHint');

    // Reset location and hall
    chainSel.innerHTML = '';

    if (!movieSel.value) {
      chainSel.disabled = true;
      chainSel.innerHTML = '<option value="">— Select a Movie first —</option>';
      if (chainHint) chainHint.style.display = '';
      filterHalls();
      updateSummary();
      return;
    }

    // Look up the movie's assigned chain IDs from the embedded map
    const movieChainIds = movieChainMap[movieSel.value] || [];

    // Filter chains to only those assigned to this movie
    const filtered = allChains.filter(c => movieChainIds.includes(c._id.toString()));

    if (filtered.length === 0) {
      chainSel.disabled = true;
      chainSel.innerHTML = '<option value="">No locations for this movie</option>';
      if (chainHint) { chainHint.textContent = 'This movie has not been assigned to any location.'; chainHint.style.display = ''; }
    } else {
      chainSel.disabled = false;
      chainSel.innerHTML = '<option value="">— Select a Location —</option>';
      filtered.forEach(function(c) {
        const opt = document.createElement('option');
        opt.value = c._id;
        opt.dataset.name = c.name;
        opt.dataset.location = c.location;
        opt.textContent = c.name + ' — ' + c.location;
        chainSel.appendChild(opt);
      });
      if (chainHint) chainHint.style.display = 'none';
    }

    // Reset hall since location changed
    filterHalls();
    updateSummary();
  }

  // Location selected → filter Hall dropdown to only show halls at that chain
  function filterHalls() {
    const chainSel = document.getElementById('chainId');
    const hallSel  = document.getElementById('hallId');
    const hint     = document.getElementById('hallHint');
    const selectedChain = chainSel.value;

    hallSel.innerHTML = '';

    if (!selectedChain) {
      hallSel.disabled = true;
      hallSel.innerHTML = '<option value="">— Select a Location first —</option>';
      if (hint) hint.style.display = '';
      return;
    }

    const filtered = allHalls.filter(h => h.chainId && h.chainId.toString() === selectedChain);

    if (filtered.length === 0) {
      hallSel.disabled = true;
      hallSel.innerHTML = '<option value="">No halls at this location</option>';
      if (hint) { hint.textContent = 'No active halls found for this location.'; hint.style.display = ''; }
    } else {
      hallSel.disabled = false;
      hallSel.innerHTML = '<option value="">— Select a Hall —</option>';
      filtered.forEach(function(h) {
        const opt = document.createElement('option');
        opt.value = h._id;
        opt.dataset.status = h.status;
        opt.dataset.name = h.name;
        opt.dataset.chain = h.chainName;
        opt.dataset.location = h.chainLocation;
        opt.textContent = h.name + (h.status === 'Under Maintenance' ? ' ⚠ (Maintenance)' : '');
        hallSel.appendChild(opt);
      });
      if (hint) hint.style.display = 'none';
    }

    updateSummary();
  }

  function updateSummary() {
    const movieSel  = document.getElementById('movieId');
    const chainSel  = document.getElementById('chainId');
    const hallSel   = document.getElementById('hallId');
    const dateSel   = document.getElementById('screeningDate');
    const timeSel   = document.getElementById('startTime');

    const movieOpt  = movieSel.options[movieSel.selectedIndex];
    const chainOpt  = chainSel.options[chainSel.selectedIndex];
    const hallOpt   = hallSel.options[hallSel.selectedIndex];

    const movieTitle = movieOpt && movieOpt.value ? movieOpt.text.replace(/\s*\(\d+ min\)/, '') : '—';
    const duration   = movieOpt ? parseInt(movieOpt.dataset.duration) || 0 : 0;
    const hallName   = hallOpt && hallOpt.value ? hallOpt.dataset.name || hallOpt.text : '—';
    const hallStatus = hallOpt ? hallOpt.dataset.status : '';
    const chainName  = chainOpt && chainOpt.value ? chainOpt.dataset.name || '—' : '—';
    const location   = chainOpt && chainOpt.value ? chainOpt.dataset.location || '—' : '—';
    const dateVal    = dateSel.value;
    const timeVal    = timeSel.value;

    document.getElementById('sumMovie').textContent    = movieTitle;
    document.getElementById('sumHall').textContent     = hallName;
    document.getElementById('sumChain').textContent    = chainName;
    document.getElementById('sumLocation').textContent = location;
    document.getElementById('sumDate').textContent     = dateVal ? new Date(dateVal + 'T00:00:00').toLocaleDateString('en-GB', { day:'numeric', month:'short', year:'numeric' }) : '—';
    document.getElementById('sumStart').textContent    = timeVal || '—';
    document.getElementById('sumDuration').textContent = duration ? duration + ' min' : '—';

    // End time
    const endBox = document.getElementById('endTimeBox');
    if (timeVal && duration) {
      const [h, m] = timeVal.split(':').map(Number);
      const end = new Date(2000, 0, 1, h, m + duration);
      const endStr = end.toTimeString().slice(0, 5);
      document.getElementById('endTimeVal').textContent = endStr;
      endBox.style.display = 'block';
    } else {
      endBox.style.display = 'none';
    }

    // Maintenance warning
    const maintWarn = document.getElementById('maintWarn');
    if (hallStatus === 'Under Maintenance') {
      maintWarn.classList.add('visible');
      document.getElementById('submitBtn').disabled = true;
      document.getElementById('submitBtn').style.opacity = '0.5';
    } else {
      maintWarn.classList.remove('visible');
      document.getElementById('submitBtn').disabled = false;
      document.getElementById('submitBtn').style.opacity = '1';
    }

    // Show overlap reminder if all fields are filled
    const overlapWarn = document.getElementById('overlapWarn');
    if (movieSel.value && hallSel.value && dateVal && timeVal) {
      overlapWarn.classList.add('visible');
    } else {
      overlapWarn.classList.remove('visible');
    }
  }

  // On page load, restore state if formData exists (validation error re-render)
  document.addEventListener('DOMContentLoaded', function() {
    const movieSel = document.getElementById('movieId');
    if (movieSel.value) {
      filterLocations();
      <% if (typeof formData !== 'undefined' && formData.chainId) { %>
        document.getElementById('chainId').value = '<%= formData.chainId %>';
        filterHalls();
        <% if (formData.hallId) { %>
          document.getElementById('hallId').value = '<%= formData.hallId %>';
        <% } %>
      <% } %>
    }
    updateSummary();
  });
</script>

</body>
</html>
