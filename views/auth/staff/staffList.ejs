<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>CineVillage — Staff Management</title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet"/>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --ink: #0a0a0f;
      --gold: #c9a84c;
      --gold-light: #e8c87a;
      --cream: #f5f0e8;
      --muted: #6b6b7a;
      --surface: #13131a;
      --surface2: #1c1c27;
      --border: rgba(201,168,76,0.15);
      --green: #2ecc71;
      --red: #e74c3c;
      --blue: #3498db;
    }

    body {
      min-height: 100vh;
      background: var(--ink);
      font-family: 'DM Sans', sans-serif;
      color: var(--cream);
      display: flex;
    }

    /* ── Sidebar ── */
    .sidebar {
      width: 240px;
      min-height: 100vh;
      background: var(--surface);
      border-right: 1px solid var(--border);
      display: flex;
      flex-direction: column;
      position: fixed;
      top: 0; left: 0; bottom: 0;
      z-index: 100;
    }

    .sidebar-brand {
      padding: 28px 24px 20px;
      border-bottom: 1px solid var(--border);
    }

    .brand-name {
      font-family: 'Playfair Display', serif;
      font-size: 1.3rem;
      font-weight: 900;
      color: var(--gold);
    }

    .brand-sub {
      font-size: 0.7rem;
      color: var(--muted);
      letter-spacing: 0.15em;
      text-transform: uppercase;
      margin-top: 3px;
    }

    .nav { flex: 1; padding: 20px 12px; }

    .nav-section {
      font-size: 0.65rem;
      font-weight: 600;
      color: var(--muted);
      letter-spacing: 0.2em;
      text-transform: uppercase;
      padding: 0 12px;
      margin-bottom: 8px;
      margin-top: 20px;
    }

    .nav-section:first-child { margin-top: 0; }

    .nav a {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 9px 12px;
      border-radius: 4px;
      color: var(--muted);
      text-decoration: none;
      font-size: 0.88rem;
      transition: all 0.15s;
      margin-bottom: 2px;
    }

    .nav a:hover { background: rgba(201,168,76,0.08); color: var(--cream); }
    .nav a.active { background: rgba(201,168,76,0.12); color: var(--gold); font-weight: 500; }
    .nav a svg { width: 16px; height: 16px; flex-shrink: 0; }

    .sidebar-footer {
      padding: 16px 12px;
      border-top: 1px solid var(--border);
    }

    .logout-btn {
      display: flex;
      align-items: center;
      gap: 10px;
      width: 100%;
      padding: 9px 12px;
      border-radius: 4px;
      background: none;
      border: none;
      color: var(--muted);
      font-family: 'DM Sans', sans-serif;
      font-size: 0.88rem;
      cursor: pointer;
      text-decoration: none;
      transition: all 0.15s;
    }

    .logout-btn:hover { background: rgba(231,76,60,0.1); color: #e74c3c; }

    /* ── Main ── */
    .main {
      margin-left: 240px;
      flex: 1;
      display: flex;
      flex-direction: column;
      min-height: 100vh;
    }

    .topbar {
      background: var(--surface);
      border-bottom: 1px solid var(--border);
      padding: 16px 32px;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .page-title {
      font-family: 'Playfair Display', serif;
      font-size: 1.4rem;
      font-weight: 700;
      color: var(--cream);
    }

    .content { padding: 32px; flex: 1; }

    /* ── Toolbar ── */
    .toolbar {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-bottom: 24px;
    }

    .search-input {
      flex: 1;
      max-width: 300px;
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.1);
      border-radius: 3px;
      padding: 9px 13px;
      color: var(--cream);
      font-family: 'DM Sans', sans-serif;
      font-size: 0.85rem;
      outline: none;
      transition: border-color 0.2s;
    }

    .search-input::placeholder { color: rgba(255,255,255,0.2); }
    .search-input:focus { border-color: var(--gold); }

    .btn-primary {
      display: inline-flex;
      align-items: center;
      gap: 7px;
      padding: 9px 20px;
      background: var(--gold);
      border: none;
      border-radius: 3px;
      color: var(--ink);
      font-family: 'DM Sans', sans-serif;
      font-size: 0.8rem;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      cursor: pointer;
      text-decoration: none;
      transition: background 0.2s;
    }

    .btn-primary:hover { background: var(--gold-light); }

    /* ── Alert ── */
    .alert {
      padding: 10px 16px;
      border-radius: 3px;
      font-size: 0.85rem;
      margin-bottom: 20px;
      border-left: 3px solid;
    }

    .alert-success {
      background: rgba(46,204,113,0.1);
      border-color: var(--green);
      color: #58d68d;
    }

    .alert-error {
      background: rgba(231,76,60,0.1);
      border-color: var(--red);
      color: #f1948a;
    }

    /* ── Table ── */
    .table-wrap {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 4px;
      overflow: hidden;
    }

    table {
      width: 100%;
      border-collapse: collapse;
    }

    thead th {
      text-align: left;
      padding: 13px 18px;
      font-size: 0.7rem;
      font-weight: 600;
      color: var(--muted);
      letter-spacing: 0.15em;
      text-transform: uppercase;
      background: rgba(255,255,255,0.02);
      border-bottom: 1px solid var(--border);
    }

    tbody td {
      padding: 14px 18px;
      font-size: 0.88rem;
      border-bottom: 1px solid var(--border);
    }

    tbody tr:last-child td { border-bottom: none; }
    tbody tr:hover { background: rgba(201,168,76,0.04); }

    .staff-name { font-weight: 500; }

    /* ── Pills ── */
    .pill {
      display: inline-block;
      padding: 3px 10px;
      border-radius: 20px;
      font-size: 0.7rem;
      font-weight: 600;
      letter-spacing: 0.08em;
    }

    .pill-admin { background: rgba(102,126,234,0.15); color: #8da4ef; }
    .pill-staff { background: rgba(255,255,255,0.06); color: var(--muted); }
    .pill-active { background: rgba(46,204,113,0.12); color: #58d68d; }
    .pill-inactive { background: rgba(231,76,60,0.12); color: #f1948a; }

    /* ── Actions ── */
    .actions {
      display: flex;
      gap: 6px;
      flex-wrap: wrap;
    }

    .btn-icon {
      display: inline-flex;
      align-items: center;
      gap: 5px;
      padding: 5px 12px;
      border-radius: 3px;
      font-size: 0.75rem;
      font-weight: 500;
      text-decoration: none;
      border: none;
      cursor: pointer;
      font-family: 'DM Sans', sans-serif;
      transition: all 0.15s;
    }

    .btn-icon svg { width: 12px; height: 12px; }

    .btn-edit {
      background: rgba(201,168,76,0.1);
      color: var(--gold);
      border: 1px solid rgba(201,168,76,0.2);
    }

    .btn-edit:hover { background: rgba(201,168,76,0.2); }

    .btn-password {
      background: rgba(52,152,219,0.1);
      color: var(--blue);
      border: 1px solid rgba(52,152,219,0.2);
    }

    .btn-password:hover { background: rgba(52,152,219,0.2); }

    .btn-delete {
      background: rgba(231,76,60,0.1);
      color: var(--red);
      border: 1px solid rgba(231,76,60,0.2);
    }

    .btn-delete:hover { background: rgba(231,76,60,0.2); }

    /* ── Empty State ── */
    .empty-state {
      text-align: center;
      padding: 60px 20px;
      color: var(--muted);
    }

    .empty-state svg { width: 48px; height: 48px; margin-bottom: 16px; opacity: 0.3; }
    .empty-state p { margin-bottom: 20px; font-size: 0.9rem; }
  </style>
</head>
<body>

<aside class="sidebar">
  <div class="sidebar-brand">
    <div class="brand-name">CineVillage</div>
    <div class="brand-sub">Admin Portal</div>
  </div>
  <nav class="nav">
    <div class="nav-section">Overview</div>
    <a href="/admin/dashboard"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>Dashboard</a>
    <div class="nav-section">Management</div>
    <a href="/admin/chains"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 7v10c0 1.1.9 2 2 2h4v-6h8v6h4c1.1 0 2-.9 2-2V7l-10-4L2 7z"/><path d="M10 19v-6h4v6"/></svg>Chains</a>
    <a href="/admin/halls"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>Halls</a>
    <a href="/admin/movies"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="2"/><line x1="7" y1="2" x2="7" y2="22"/><line x1="17" y1="2" x2="17" y2="22"/><line x1="2" y1="12" x2="22" y2="12"/></svg>Movies</a>
    <a href="/admin/screenings"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="3" y1="10" x2="21" y2="10"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="16" y1="2" x2="16" y2="6"/></svg>Screenings</a>
    <a href="/admin/staff" class="active"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>Staff Management</a>
  </nav>
  <div class="sidebar-footer">
    <a href="/logout" class="logout-btn"><svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>Sign Out</a>
  </div>
</aside>

<main class="main">
  <div class="topbar">
    <div class="page-title">Staff Management</div>
    <span style="font-size:0.82rem; color:var(--muted)"><%= typeof staff !== 'undefined' ? staff.length : 0 %> members</span>
  </div>

  <div class="content">
    <% if (success && success.length > 0) { %>
      <div class="alert alert-success"><%= success[0] %></div>
    <% } %>
    <% if (error && error.length > 0) { %>
      <div class="alert alert-error"><%= error[0] %></div>
    <% } %>

    <div class="toolbar">
      <input type="text" class="search-input" placeholder="Search staff…" id="searchInput" onkeyup="filterTable()"/>
      <a href="/admin/staff/create" class="btn-primary">
        <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        Add Staff
      </a>
    </div>

    <div class="table-wrap">
      <% if (typeof staff !== 'undefined' && staff.length > 0) { %>
        <table id="staffTable">
          <thead>
            <tr>
              <th>Username</th>
              <th>Role</th>
              <th>Status</th>
              <th>Created</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% staff.forEach(function(member) { %>
              <tr>
                <td class="staff-name"><%= member.username %></td>
                <td>
                  <span class="pill <%= member.role === 'admin' ? 'pill-admin' : 'pill-staff' %>">
                    <%= member.role ? member.role.toUpperCase() : 'STAFF' %>
                  </span>
                </td>
                <td>
                  <span class="pill <%= member.isActive !== false ? 'pill-active' : 'pill-inactive' %>">
                    <%= member.isActive !== false ? 'Active' : 'Inactive' %>
                  </span>
                </td>
                <td style="font-size:0.8rem; color:var(--muted);">
                  <%= member.createdAt ? new Date(member.createdAt).toLocaleDateString('en-GB', { day:'numeric', month:'short', year:'numeric' }) : '—' %>
                </td>
                <td>
                  <div class="actions">
                    <a href="/admin/staff/edit/<%= member._id %>" class="btn-icon btn-edit">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                      Edit
                    </a>
                    <a href="/admin/staff/change-password/<%= member._id %>" class="btn-icon btn-password">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
                      Password
                    </a>
                    <% if (member._id.toString() !== userId.toString()) { %>
                      <form method="POST" action="/admin/staff/delete/<%= member._id %>" onsubmit="return confirm('Are you sure you want to delete this staff member?')" style="display:inline;">
                        <button type="submit" class="btn-icon btn-delete">
                          <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 01-2 2H8a2 2 0 01-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4a1 1 0 011-1h4a1 1 0 011 1v2"/></svg>
                          Delete
                        </button>
                      </form>
                    <% } %>
                  </div>
                </td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      <% } else { %>
        <div class="empty-state">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          <p>No staff members found.</p>
          <a href="/admin/staff/create" class="btn-primary">Add First Staff</a>
        </div>
      <% } %>
    </div>
  </div>
</main>

<script>
function filterTable() {
  const q = document.getElementById('searchInput').value.toLowerCase();
  const rows = document.querySelectorAll('#staffTable tbody tr');
  rows.forEach(row => {
    row.style.display = row.textContent.toLowerCase().includes(q) ? '' : 'none';
  });
}
</script>
</body>
</html>
